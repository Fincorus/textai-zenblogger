## Telegram
BOT_TOKEN=123456:ABCDEF_your_bot_token
ADMIN_TELEGRAM_ID=123456789
TG_CHANNEL_ID=@your_channel_or_-1001234567890

## Run mode
BOT_MODE=polling
# BOT_MODE=webhook
WEBHOOK_BASE_URL=https://your-public-domain.example
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

## LLM provider (via litellm)
LLM_PROVIDER=xai
LLM_MODEL=grok-4.1-fast
LLM_FALLBACKS=openai:gpt-4o-mini,gemini:gemini-2.0-flash,groq:llama-3.1-70b-versatile
LLM_TIMEOUT_S=120

## API keys (fill what you use)
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

## Article
ARTICLE_MIN_WORDS=1500
ARTICLE_MAX_WORDS=3000
DEFAULT_TOPICS=Искусственный интеллект,Продуктивность,Маркетинг,Здоровье,Финансы,Саморазвитие

## Images
IMAGE_MODE=unsplash
UNSPLASH_SOURCE_URL=https://source.unsplash.com/featured/1280x720/?{query}
LLM_IMAGE_MODEL=grok-2-image

## Dzen
DZEN_COOKIES_PATH=cookies_dzen.json
DZEN_HEADLESS=true
DZEN_RUBRIC=
DZEN_TAGS=AI,технологии,обучение

## Scheduler
SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 10 * * *
SCHEDULER_PUBLISH_TARGET=tg

## Logging
LOG_LEVEL=INFO

